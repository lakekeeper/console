VITE_IDP_AUTHORITY="http://localhost:30080/realms/iceberg/"
VITE_IDP_CLIENT_ID="lakekeeper"
VITE_IDP_REDIRECT_PATH="/callback"
VITE_IDP_SCOPE="openid profile email lakekeeper"
VITE_IDP_RESOURCE=""
VITE_IDP_POST_LOGOUT_REDIRECT_PATH="/logout"
# Optional: override the post-logout redirect with an absolute URL (e.g. a cloud
# portal login page) for IdPs that only allow pre-registered post-logout URLs.
VITE_IDP_POST_LOGOUT_REDIRECT_URL=""
# Optional: set to true to omit post_logout_redirect_uri entirely (RFC-optional).
VITE_IDP_POST_LOGOUT_REDIRECT_DISABLED=false
VITE_IDP_TOKEN_TYPE="access_token"
VITE_ENABLE_AUTHENTICATION=true
VITE_ENABLE_PERMISSIONS=true
VITE_ENABLE_USER_SURVEYS=true
VITE_APP_ICEBERG_CATALOG_URL="http://localhost:8181"
VITE_BASE_URL_PREFIX=""

